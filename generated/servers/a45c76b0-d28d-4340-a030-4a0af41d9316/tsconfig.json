{
  "compilerOptions": {
    "target": "ES2022",

    "module": "NodeNext",

    "moduleResolution": "NodeNext",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "resolveJsonModule": true,

    "isolatedModules": true,

    "types": ["node"],

    "outDir": "dist" // 
  },

  "include": ["./**/*.ts"],

  "exclude": ["node_modules"]
}